{
    "manifest_version": 3,
    "name": "StyleSwift - 一键个性化任何网站！",
    "version": "1.0",
    "description": "普通人一句话轻松个性化任何网站，让网站更符合你的品味！",
    "author": "zane@llmgpuhelper.com",
    "icons": {
        "48": "images/icon5_48.png",
        "128": "images/icon5.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "storage",
        "scripting",
        "windows",
        "system.display"
    ],
    "host_permissions": [
        "<all_urls>",
        "https://styleswift.zeabur.app/*"
    ],
    "action": {
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "options_page": "options.html",
    "background": {
        "service_worker": "background.js"
    }
}